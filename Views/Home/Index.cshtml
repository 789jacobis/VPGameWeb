@{
    ViewData["Title"] = "VPGameWeb";
}

<section class="home-hero">
    <div class="home-hero-content">
        <h1>堅持三分鐘吧！</h1>
        <p>VP 遊戲資料展示網站</p>

        <a href="#guide-section" class="btn btn-warning btn-lg home-hero-button">
            開始導覽
        </a>
    </div>
</section>

<section id="guide-section" class="home-guide">
    <div class="text-center mb-5">
        <p class="text-muted mb-1">Guide</p>
        <h2>瀏覽遊戲資料</h2>
    </div>

    <div class="row">
        <div class="col-md mb-3">
            <a asp-controller="Lore" asp-action="Index" class="guide-card">
                <h5>劇情設定</h5>
                <p>查看世界觀與劇情資料。</p>
            </a>
        </div>

        <div class="col-md mb-3">
            <a asp-controller="Skill" asp-action="Index" class="guide-card">
                <h5>技能圖鑑</h5>
                <p>查看玩家技能與升級效果。</p>
            </a>
        </div>

        <div class="col-md mb-3">
            <a asp-controller="Monster" asp-action="Index" class="guide-card">
                <h5>怪物圖鑑</h5>
                <p>查看一般怪物資料。</p>
            </a>
        </div>

        <div class="col-md mb-3">
            <a asp-controller="Boss" asp-action="Index" class="guide-card">
                <h5>Boss圖鑑</h5>
                <p>查看 Boss 與攻擊技能。</p>
            </a>
        </div>

        <div class="col-md mb-3">
            <a asp-controller="Item" asp-action="Index" class="guide-card">
                <h5>道具圖鑑</h5>
                <p>查看掉落道具與效果。</p>
            </a>
        </div>
    </div>
</section>