@model VpGameWeb.Models.Skill

<h1>@Model.Name</h1>

<p>
    <strong>分類：</strong>
    @Model.Category
</p>

<p>
    <strong>說明：</strong>
    @Model.Description
</p>

@if (Model.Levels.Count > 0)
{
    <h2>升級表</h2>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>等級</th>
                <th>效果</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var level in Model.Levels)
            {
                <tr>
                    <td>LV @level.Level</td>
                    <td>@level.Description</td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="Skill" asp-action="Index" class="btn btn-secondary">
    返回技能列表
</a>