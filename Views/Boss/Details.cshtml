@model VpGameWeb.Models.Boss

<h1>@Model.Name</h1>

<img src="@Model.IconUrl"
     class="detail-main-img"
     alt="@Model.Name" />

<p><strong>HP：</strong>@Model.Hp</p>
<p><strong>攻擊力：</strong>@Model.Attack</p>
<p><strong>移動速度：</strong>@Model.MoveSpeed</p>

<p><strong>名字：</strong>@Model.RealName</p>
<p><strong>年齡：</strong>@Model.Age</p>
<p><strong>萌點：</strong>@Model.Traits</p>
<p><strong>戰鬥場景：</strong>@Model.BattleScene</p>
<p><strong>搭配小怪：</strong>@Model.MonsterGroup</p>
<p><strong>簡介：</strong>@Model.Description</p>

<h2>技能列表</h2>

<ul>
    @foreach (var skill in Model.Skills)
    {
        <li>@skill</li>
    }
</ul>

<a asp-controller="Boss"
   asp-action="Index"
   class="btn btn-secondary">
    返回 Boss 圖鑑
</a>