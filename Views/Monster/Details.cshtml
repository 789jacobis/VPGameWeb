@model VpGameWeb.Models.Monster

<h1>@Model.Name</h1>

<img src="@Model.IconUrl"
     class="detail-main-img"
     alt="@Model.Name" />

<div class="card">
    <div class="card-body">

        <p>
            <strong>類型：</strong>
            @Model.Type
        </p>

        <p>
            <strong>HP：</strong>
            @Model.Hp
        </p>

        <p>
            <strong>攻擊力：</strong>
            @Model.Attack
        </p>

        <p>
            <strong>移動速度：</strong>
            @Model.MoveSpeed
        </p>

        <p>
            <strong>經驗值：</strong>
            @Model.ExpReward
        </p>

        <p>
            <strong>介紹：</strong>
            @Model.Description
        </p>

        <a asp-controller="Monster" asp-action="Index" class="btn btn-secondary">
            返回怪物列表
        </a>

    </div>
</div>